<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Siaxen — Stylescape</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap');

:root{--base:#090B12;--surf:#12151E;--acc:#C08D60;--tx:#F5F0EB}

*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:'Inter',sans-serif;background:var(--base);color:var(--tx);overflow-x:hidden;-webkit-font-smoothing:antialiased}
::selection{background:var(--acc);color:var(--base)}
.pad{padding-left:clamp(16px,4vw,56px);padding-right:clamp(16px,4vw,56px)}

.progress{position:fixed;top:0;left:0;height:2px;background:var(--acc);z-index:100;width:0;transition:width .05s}

.bg-grid{position:fixed;inset:0;z-index:0;pointer-events:none;background-image:linear-gradient(var(--acc) 1px,transparent 1px),linear-gradient(90deg,var(--acc) 1px,transparent 1px);background-size:80px 80px;opacity:.012}
.bg-vig{position:fixed;inset:0;z-index:0;pointer-events:none;background:radial-gradient(ellipse at 50% 50%,transparent 30%,var(--base) 80%)}
body>:not(.bg-grid):not(.bg-vig):not(.progress){position:relative;z-index:1}

.dv{height:1px;background:var(--acc);opacity:.06}

.sh{padding-top:clamp(56px,8vw,96px);padding-bottom:clamp(20px,3vw,32px)}
.sh-num{font-size:10px;font-weight:700;letter-spacing:4px;color:var(--acc)}
.sh-title{font-size:clamp(24px,3.5vw,36px);font-weight:800;letter-spacing:-1px;color:var(--tx);opacity:.8;margin-top:4px}

.reveal{opacity:0;transform:translateY(24px);transition:opacity .8s cubic-bezier(.16,1,.3,1),transform .8s cubic-bezier(.16,1,.3,1)}
.reveal.visible{opacity:1;transform:translateY(0)}
.rd1{transition-delay:.1s}.rd2{transition-delay:.2s}.rd3{transition-delay:.3s}

/* HERO */
.hero{min-height:100vh;display:flex;align-items:center;position:relative;overflow:hidden;padding:clamp(24px,4vw,56px)}
.hero-bg{position:absolute;inset:0;pointer-events:none;background:linear-gradient(160deg,var(--surf) 0%,transparent 30%),linear-gradient(340deg,var(--surf) 0%,transparent 30%)}
.hero-arch{position:absolute;inset:0;pointer-events:none;overflow:hidden}
.frag-line{position:absolute;background:var(--acc);opacity:.04}
.fl1{width:60px;height:1px;top:15%;left:5%;transform:rotate(23deg)}
.fl2{width:40px;height:1px;top:25%;left:8%;transform:rotate(-15deg)}
.fl3{width:80px;height:1px;top:35%;left:2%;transform:rotate(45deg)}
.fl4{width:50px;height:1px;top:48%;left:12%;transform:rotate(-30deg)}
.fl5{width:35px;height:1px;top:58%;left:4%;transform:rotate(60deg)}
.fl6{width:70px;height:1px;top:68%;left:9%;transform:rotate(-8deg)}
.fl7{width:45px;height:1px;top:78%;left:3%;transform:rotate(35deg)}
.frag-dot{position:absolute;width:3px;height:3px;border-radius:50%;background:var(--acc)}
.fd1{top:20%;left:10%;opacity:.06}.fd2{top:40%;left:6%;opacity:.05}.fd3{top:60%;left:14%;opacity:.08}.fd4{top:75%;left:8%;opacity:.04}
.struct-v{position:absolute;width:1px;top:10%;bottom:10%;background:var(--acc)}
.sv1{right:8%;opacity:.06}.sv2{right:16%;opacity:.05}.sv3{right:24%;opacity:.04}
.struct-h{position:absolute;height:1px;right:3%;width:25%;background:var(--acc)}
.shx1{top:25%;opacity:.05}.shx2{top:40%;opacity:.06}.shx3{top:55%;opacity:.05}.shx4{top:70%;opacity:.04}
.struct-node{position:absolute;width:4px;height:4px;border-radius:50%;background:var(--acc)}
.sn1{top:25%;right:8%;opacity:.15}.sn2{top:40%;right:16%;opacity:.1}.sn3{top:55%;right:8%;opacity:.12}.sn4{top:40%;right:8%;opacity:.18}

.hero-inner{position:relative;z-index:2;width:100%;display:grid;grid-template-columns:1.3fr 1fr;gap:clamp(32px,5vw,80px);align-items:center}
.hero-label{font-size:10px;font-weight:700;letter-spacing:4px;color:var(--acc);margin-bottom:clamp(20px,3vw,36px);opacity:0;animation:hF .8s ease .2s forwards}
.hero-title{font-size:clamp(44px,7vw,88px);font-weight:900;letter-spacing:clamp(-2px,-.7vw,-1.5px);line-height:.9}
.hero-w{color:var(--tx);display:block;opacity:0;animation:hF .8s ease .3s forwards}
.hero-c{color:var(--acc);display:block;opacity:0;animation:hF .8s ease .45s forwards}
.hero-desc{margin-top:clamp(16px,3vw,28px);font-size:clamp(11px,1.2vw,13px);font-weight:400;color:var(--tx);opacity:0;line-height:1.9;max-width:440px;animation:hF .8s ease .6s forwards}
.hero-desc-v{opacity:.3!important}
.hero-bar{width:48px;height:3px;background:var(--acc);margin-top:clamp(14px,2vw,20px);opacity:0;animation:hF .8s ease .7s forwards}
.hero-bar-v{opacity:.5!important}
@keyframes hF{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}

.hero-pal-wrap{opacity:0;animation:hF .8s ease .5s forwards}
.hero-pal{display:grid;grid-template-columns:1fr 1fr;gap:3px}
.hp{height:clamp(100px,14vw,140px);display:flex;flex-direction:column;justify-content:flex-end;padding:clamp(12px,1.5vw,18px);transition:transform .4s cubic-bezier(.16,1,.3,1),box-shadow .4s}
.hp:hover{transform:translateY(-4px);box-shadow:0 8px 24px rgba(0,0,0,.2)}
.hp1{background:var(--base);border:1px solid rgba(192,141,96,.08)}
.hp2{background:var(--surf)}.hp3{background:var(--acc)}.hp4{background:var(--tx)}
.hp-role{font-size:7px;font-weight:700;letter-spacing:3px;margin-bottom:2px}
.hp-name{font-size:13px;font-weight:800;letter-spacing:-.2px;margin-bottom:1px}
.hp-hex{font-size:10px;font-weight:500;letter-spacing:1px}
.hp1 .hp-role,.hp2 .hp-role{color:var(--tx);opacity:.3}
.hp1 .hp-name,.hp2 .hp-name{color:var(--tx);opacity:.65}
.hp1 .hp-hex,.hp2 .hp-hex{color:var(--tx);opacity:.35}
.hp3 .hp-role{color:var(--base);opacity:.35}.hp3 .hp-name{color:var(--base);opacity:.7}.hp3 .hp-hex{color:var(--base);opacity:.4}
.hp4 .hp-role{color:var(--base);opacity:.25}.hp4 .hp-name{color:var(--base);opacity:.5}.hp4 .hp-hex{color:var(--base);opacity:.3}
.hero-pal-label{font-size:7px;font-weight:700;letter-spacing:4px;color:var(--tx);opacity:.08;text-align:center;margin-top:8px}

/* MOOD */
.mood{padding-bottom:clamp(40px,5vw,64px)}
.mood-row1{display:grid;grid-template-columns:repeat(4,1fr);gap:4px;margin-bottom:4px}
.mood-row2{display:grid;grid-template-columns:repeat(3,1fr);gap:4px}
.mc{position:relative;overflow:hidden;aspect-ratio:1/1;background:var(--surf);transition:transform .5s cubic-bezier(.16,1,.3,1)}
.mc:hover{transform:scale(1.008);z-index:3}
.mc::after{content:'';position:absolute;inset:0;border:1px solid var(--acc);opacity:.04;pointer-events:none}
.mc-lbl{position:absolute;bottom:clamp(10px,1.5vw,14px);left:clamp(10px,1.5vw,14px);font-size:7px;font-weight:700;letter-spacing:3px;color:var(--acc);opacity:.3;z-index:5}

.ph{background:var(--surf);display:flex;align-items:center;justify-content:center;border:1px dashed rgba(192,141,96,.12);aspect-ratio:4/3;transition:all .4s}
.ph:hover{border-color:rgba(192,141,96,.25);background:rgba(18,21,30,.8)}
.ph-inner{display:flex;flex-direction:column;align-items:center;gap:10px}
.ph-icon{width:40px;height:40px;border-radius:50%;border:1.5px solid var(--acc);opacity:.12;display:flex;align-items:center;justify-content:center;transition:all .4s}
.ph:hover .ph-icon{opacity:.2;transform:scale(1.1)}
.ph-plus{font-size:18px;font-weight:300;color:var(--acc);opacity:.35}
.ph-text{font-size:7px;font-weight:700;letter-spacing:3px;color:var(--tx);opacity:.06}
.ph-num{position:absolute;top:12px;right:14px;font-size:8px;font-weight:800;color:var(--acc);opacity:.1}

/* MC1: Perspective */
.mc1 .pg-h{position:absolute;height:1px;background:var(--acc)}
.pgh1{top:8%;left:40%;right:40%;opacity:.2}
.pgh2{top:18%;left:32%;right:32%;opacity:.16}
.pgh3{top:28%;left:24%;right:24%;opacity:.13}
.pgh4{top:38%;left:16%;right:16%;opacity:.11}
.pgh5{top:48%;left:10%;right:10%;opacity:.09}
.pgh6{top:58%;left:5%;right:5%;opacity:.07}
.pgh7{top:68%;left:2%;right:2%;opacity:.06}
.pgh8{top:78%;left:0;right:0;opacity:.05}
.pgh9{top:88%;left:0;right:0;opacity:.04}
.mc1 .pg-v{position:absolute;width:1px;background:var(--acc);top:8%;height:84%;left:50%;transform-origin:top center}
.pgv1{transform:rotate(0);opacity:.12}.pgv2{transform:rotate(6deg);opacity:.09}.pgv3{transform:rotate(-6deg);opacity:.09}
.pgv4{transform:rotate(12deg);opacity:.07}.pgv5{transform:rotate(-12deg);opacity:.07}
.pgv6{transform:rotate(18deg);opacity:.05}.pgv7{transform:rotate(-18deg);opacity:.05}
.pgv8{transform:rotate(24deg);opacity:.04}.pgv9{transform:rotate(-24deg);opacity:.04}
.pgv10{transform:rotate(30deg);opacity:.03}.pgv11{transform:rotate(-30deg);opacity:.03}
.mc1 .pg-vp{position:absolute;top:8%;left:50%;transform:translate(-50%,-50%);width:8px;height:8px;border-radius:50%;background:var(--acc);opacity:.35;box-shadow:0 0 16px rgba(192,141,96,.3)}

/* MC2: Woven */
.mc2 .wg-h{position:absolute;left:10%;right:10%;height:2px;background:var(--acc)}
.wgh1{top:14%;opacity:.06}.wgh2{top:26%;opacity:.08}.wgh3{top:38%;opacity:.1}
.wgh4{top:50%;opacity:.13}.wgh5{top:62%;opacity:.1}.wgh6{top:74%;opacity:.08}.wgh7{top:86%;opacity:.06}
.mc2 .wg-v{position:absolute;top:10%;bottom:10%;width:2px;background:var(--acc)}
.wgv1{left:14%;opacity:.06}.wgv2{left:26%;opacity:.08}.wgv3{left:38%;opacity:.1}
.wgv4{left:50%;opacity:.13}.wgv5{left:62%;opacity:.1}.wgv6{left:74%;opacity:.08}.wgv7{left:86%;opacity:.06}
.mc2 .wg-x{position:absolute;width:8px;height:8px;background:var(--acc)}
.wgx1{top:calc(26% - 3px);left:calc(26% - 3px);opacity:.18}
.wgx2{top:calc(38% - 3px);left:calc(38% - 3px);opacity:.22}
.wgx3{top:calc(50% - 3px);left:calc(50% - 3px);opacity:.35}
.wgx4{top:calc(62% - 3px);left:calc(62% - 3px);opacity:.22}
.wgx5{top:calc(74% - 3px);left:calc(74% - 3px);opacity:.18}
.wgx6{top:calc(38% - 3px);left:calc(62% - 3px);opacity:.14}
.wgx7{top:calc(62% - 3px);left:calc(38% - 3px);opacity:.14}
.wgx8{top:calc(50% - 3px);left:calc(26% - 3px);opacity:.16}
.wgx9{top:calc(50% - 3px);left:calc(74% - 3px);opacity:.16}
.wgx10{top:calc(26% - 3px);left:calc(50% - 3px);opacity:.16}
.wgx11{top:calc(74% - 3px);left:calc(50% - 3px);opacity:.16}

/* MC3: Topographic — FIXED centering */
.mc3 .tp-c{position:absolute;border:1.5px solid var(--acc);border-radius:52% 46% 54% 48%}
.tpc1{top:10%;left:8%;width:84%;height:80%;opacity:.05;transform:rotate(-4deg)}
.tpc2{top:15%;left:13%;width:74%;height:70%;opacity:.07;transform:rotate(-2deg)}
.tpc3{top:20%;left:18%;width:64%;height:60%;opacity:.09}
.tpc4{top:25%;left:23%;width:54%;height:50%;opacity:.12;transform:rotate(1deg)}
.tpc5{top:30%;left:27%;width:46%;height:40%;opacity:.15;transform:rotate(2deg)}
.tpc6{top:34%;left:31%;width:38%;height:32%;opacity:.19;transform:rotate(2deg)}
.tpc7{top:38%;left:35%;width:30%;height:24%;opacity:.24;transform:rotate(1deg)}
.tpc8{top:41%;left:38%;width:24%;height:18%;opacity:.3}
.mc3 .tp-peak{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:8px;height:8px;border-radius:50%;background:var(--acc);opacity:.4;box-shadow:0 0 14px rgba(192,141,96,.25)}
.mc3 .tp-cx{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:16%;height:1px;background:var(--acc);opacity:.1}
.mc3 .tp-cy{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:1px;height:16%;background:var(--acc);opacity:.1}

/* MC4: Scattered → Synchronized */
.mc4 .sc-dot{position:absolute;width:5px;height:5px;border-radius:50%;background:var(--acc)}
.scd1{top:14%;left:8%;opacity:.15}.scd2{top:26%;left:16%;opacity:.1}.scd3{top:20%;left:28%;opacity:.12}
.scd4{top:40%;left:10%;opacity:.08}.scd5{top:52%;left:22%;opacity:.14}.scd6{top:60%;left:6%;opacity:.1}
.scd7{top:70%;left:18%;opacity:.15}.scd8{top:82%;left:12%;opacity:.08}.scd9{top:36%;left:32%;opacity:.06}
.mc4 .sc-line{position:absolute;height:1px;background:var(--acc)}
.scl1{top:16%;left:11%;width:14px;transform:rotate(25deg);opacity:.08}
.scl2{top:28%;left:19%;width:10px;transform:rotate(-30deg);opacity:.06}
.scl3{top:52%;left:25%;width:12px;transform:rotate(50deg);opacity:.07}
.scl4{top:72%;left:21%;width:16px;transform:rotate(-15deg);opacity:.09}
.mc4 .sc-mid{position:absolute;top:8%;bottom:8%;left:44%;width:1px;background:var(--acc);opacity:.06}
.mc4 .sc-arr{position:absolute;top:50%;left:38%;width:12%;height:1px;background:var(--acc);opacity:.1}
.mc4 .sc-arr-h{position:absolute;top:50%;left:49%;width:0;height:0;border-top:4px solid transparent;border-bottom:4px solid transparent;border-left:6px solid var(--acc);opacity:.15;transform:translateY(-50%)}
.mc4 .sy-v{position:absolute;width:1px;top:10%;bottom:10%;background:var(--acc)}
.syv1{right:30%;opacity:.08}.syv2{right:16%;opacity:.07}
.mc4 .sy-h{position:absolute;height:1px;left:54%;right:5%;background:var(--acc)}
.syh1{top:20%;opacity:.06}.syh2{top:36%;opacity:.07}.syh3{top:52%;opacity:.08}.syh4{top:68%;opacity:.07}.syh5{top:84%;opacity:.06}
.mc4 .sy-n{position:absolute;width:5px;height:5px;border-radius:50%;background:var(--acc)}
.syn1{top:20%;right:30%;opacity:.2}.syn2{top:20%;right:16%;opacity:.16}
.syn3{top:36%;right:30%;opacity:.22}.syn4{top:36%;right:16%;opacity:.28}
.syn5{top:52%;right:30%;opacity:.3}.syn6{top:52%;right:16%;opacity:.25}
.syn7{top:68%;right:30%;opacity:.2}.syn8{top:68%;right:16%;opacity:.16}
.syn9{top:84%;right:30%;opacity:.14}.syn10{top:84%;right:16%;opacity:.1}
.mc4 .sc-ll{position:absolute;bottom:clamp(10px,1.5vw,14px);left:clamp(10px,1.5vw,14px);font-size:6px;font-weight:700;letter-spacing:2px;color:var(--acc);opacity:.2}
.mc4 .sc-lr{position:absolute;bottom:clamp(10px,1.5vw,14px);right:clamp(10px,1.5vw,14px);font-size:6px;font-weight:700;letter-spacing:2px;color:var(--acc);opacity:.3}

/* TYPOGRAPHY */
.typo{padding-bottom:clamp(40px,5vw,64px)}
.typo-hero{background:var(--surf);padding:clamp(28px,5vw,56px);margin-bottom:4px;position:relative;overflow:hidden;transition:background .4s}
.typo-hero:hover{background:rgba(18,21,30,.9)}
.typo-bg{position:absolute;inset:0;pointer-events:none}
.tb-fl{position:absolute;height:1px;background:var(--acc)}
.tbf1{top:18%;left:2%;width:50px;transform:rotate(20deg);opacity:.04}
.tbf2{top:32%;left:5%;width:35px;transform:rotate(-25deg);opacity:.03}
.tbf3{top:48%;left:3%;width:60px;transform:rotate(35deg);opacity:.04}
.tbf4{top:62%;left:8%;width:40px;transform:rotate(-10deg);opacity:.03}
.tb-grid{position:absolute;right:0;top:0;bottom:0;width:35%;background-image:linear-gradient(var(--acc) 1px,transparent 1px),linear-gradient(90deg,var(--acc) 1px,transparent 1px);background-size:32px 32px;opacity:.02}
.tb-flow{position:absolute;top:50%;left:30%;width:25%;height:1px;background:linear-gradient(to right,var(--acc),transparent,var(--acc));opacity:.05;transform:translateY(-50%)}
.typo-hero-tag{font-size:9px;font-weight:700;letter-spacing:4px;color:var(--acc);opacity:.5;margin-bottom:20px;position:relative;z-index:2}
.typo-hero-text{font-size:clamp(40px,6vw,80px);font-weight:900;letter-spacing:clamp(-2px,-.6vw,-1px);line-height:.93;color:var(--tx);position:relative;z-index:2}
.typo-hero-text em{font-style:normal;color:var(--acc)}
.typo-row{display:grid;grid-template-columns:1fr 1fr 1fr;gap:4px}
.tc{background:var(--surf);padding:clamp(18px,2.5vw,32px);transition:background .4s,transform .4s cubic-bezier(.16,1,.3,1)}
.tc:hover{background:rgba(18,21,30,.9);transform:translateY(-2px)}
.tc-tag{font-size:8px;font-weight:700;letter-spacing:3px;color:var(--acc);opacity:.45;margin-bottom:12px}
.tc-spec{font-size:9px;font-weight:500;color:var(--tx);opacity:.15;letter-spacing:1px;margin-top:12px;padding-top:10px;border-top:1px solid rgba(192,141,96,.04)}
.tw-row{display:grid;grid-template-columns:repeat(7,1fr);gap:4px;margin-top:4px}
.tw{background:var(--surf);height:clamp(56px,8vw,72px);display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px;transition:all .3s cubic-bezier(.16,1,.3,1)}
.tw:hover{background:var(--base);transform:translateY(-2px);box-shadow:0 4px 16px rgba(0,0,0,.2)}
.tw-s{font-size:clamp(18px,2.5vw,26px);color:var(--tx);opacity:.15;letter-spacing:-1px;transition:all .3s}
.tw:hover .tw-s{color:var(--acc);opacity:1}
.tw-n{font-size:7px;font-weight:600;letter-spacing:2px;color:var(--tx);opacity:.1;transition:all .3s}
.tw:hover .tw-n{color:var(--acc);opacity:.3}

/* DATA */
.data{padding-bottom:clamp(40px,5vw,64px)}
.data-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:4px}
.data-panel{background:var(--surf);padding:clamp(24px,3.5vw,40px);position:relative;overflow:hidden;transition:background .4s,transform .4s cubic-bezier(.16,1,.3,1)}
.data-panel:hover{background:rgba(18,21,30,.9);transform:translateY(-2px)}
.data-panel::before{content:'';position:absolute;inset:0;pointer-events:none;background-image:linear-gradient(var(--acc) 1px,transparent 1px),linear-gradient(90deg,var(--acc) 1px,transparent 1px);background-size:40px 40px;opacity:.015}
.data-title{font-size:8px;font-weight:700;letter-spacing:3px;color:var(--acc);opacity:.5;margin-bottom:24px;position:relative;z-index:2}
.bar-wrap{position:relative;z-index:2}
.bar-chart{display:flex;align-items:flex-end;gap:clamp(4px,1vw,8px);height:clamp(120px,16vw,180px);padding-top:24px}
.bar-ref{position:absolute;left:0;right:0;height:1px;background:var(--acc);opacity:.04}
.bar-r1{top:25%}.bar-r2{top:50%}.bar-r3{top:75%}
.bar{flex:1;background:var(--acc);transition:all .4s cubic-bezier(.16,1,.3,1);border-radius:1px 1px 0 0;position:relative}
.bar:hover{opacity:1!important;transform:scaleY(1.04);transform-origin:bottom}
.bar-base{height:1.5px;background:var(--acc);opacity:.12}
.bar-labels{display:flex;gap:clamp(4px,1vw,8px);margin-top:10px}
.bar-label{flex:1;font-size:7px;font-weight:600;letter-spacing:1px;color:var(--tx);opacity:.1;text-align:center}
.bar-val{position:absolute;top:-16px;left:50%;transform:translateX(-50%);font-size:6px;font-weight:700;color:var(--acc);opacity:0;transition:opacity .3s;letter-spacing:1px}
.bar:hover .bar-val{opacity:.4}
.line-wrap{position:relative;z-index:2}
.line-chart{position:relative;height:clamp(120px,16vw,180px)}
.line-grid{position:absolute;inset:0;background-image:linear-gradient(var(--acc) 1px,transparent 1px);background-size:100% 25%;opacity:.03}
.line-grid-v{position:absolute;inset:0;background-image:linear-gradient(90deg,var(--acc) 1px,transparent 1px);background-size:20% 100%;opacity:.02}
.line-chart svg{width:100%;height:100%;position:relative;z-index:2}
.line-labels{display:flex;justify-content:space-between;margin-top:10px}
.line-label{font-size:7px;font-weight:600;letter-spacing:1px;color:var(--tx);opacity:.1}
.donut-wrap{display:flex;align-items:center;gap:clamp(20px,3vw,36px);position:relative;z-index:2}
.donut{width:clamp(120px,14vw,160px);height:clamp(120px,14vw,160px);border-radius:50%;position:relative;flex-shrink:0;transition:transform .4s}
.data-panel:hover .donut{transform:scale(1.03)}
.donut-track{position:absolute;inset:0;border-radius:50%;border:clamp(12px,1.8vw,18px) solid var(--acc);opacity:.1}
.donut-fill{position:absolute;inset:0;border-radius:50%;border:clamp(12px,1.8vw,18px) solid var(--acc);opacity:.5;clip-path:polygon(50% 0%,100% 0%,100% 100%,50% 100%,50% 50%)}
.donut-center{position:absolute;inset:clamp(12px,1.8vw,18px);border-radius:50%;background:var(--surf);display:flex;align-items:center;justify-content:center;flex-direction:column;gap:2px;transition:background .4s}
